# Manuscript Alert — Environment Variables
# Copy to .env and fill in values as needed.
# All variables are optional until their respective migration steps.

# Step 5: CORS — add your Vercel URL here when deployed
# e.g. ALLOWED_ORIGINS=https://manuscript-alert.vercel.app,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Step 3: Clerk Auth (https://dashboard.clerk.com → API Keys)
# JWKS URL: Clerk dashboard → API Keys → Advanced → JWKS URL
CLERK_JWKS_URL=
# Frontend publishable key (starts with pk_)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# Backend secret key (starts with sk_) — keep this private, never commit
CLERK_SECRET_KEY=

# Step 4: Neon Database
DATABASE_URL=

# Step 6: Agent Pipeline
ANTHROPIC_API_KEY=

# Step 7: Pinecone + Knowledge Base
PINECONE_API_KEY=
